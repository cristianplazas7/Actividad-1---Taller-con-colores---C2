<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Exploración Espacial</title>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box;font-family:'Orbitron',sans-serif}
    body{background:#050816;color:white;overflow-x:hidden}

    header{
      display:flex;justify-content:space-between;align-items:center;
      padding:15px 40px;background:rgba(0,0,0,0.6);
      position:fixed;width:100%;z-index:10;backdrop-filter:blur(8px)
    }

    header h1{color:#ffd700;font-size:1.5rem}

    nav a{margin-left:20px;text-decoration:none;color:white;transition:.3s}
    nav a:hover{color:#ffd700}

    .hero{
      height:100vh;display:flex;flex-direction:column;
      justify-content:center;align-items:center;text-align:center;
      position:relative;overflow:hidden
    }

    .hero img{
      width:320px;transition:transform 1.2s ease;
      z-index:2
    }

    .title{font-size:3rem;margin-top:20px}

    .btn{
      margin-top:20px;padding:15px 30px;background:#ffd700;
      border:none;cursor:pointer;font-weight:bold;
      transition:.3s;border-radius:8px
    }
    .btn:hover{background:white}

    /* PARALLAX ESTRELLAS */
    .stars, .stars2{
      position:absolute;width:100%;height:100%;top:0;left:0;
      background:radial-gradient(white 1px, transparent 1px);
      background-size:40px 40px;opacity:.4
    }

    .stars2{background-size:80px 80px;opacity:.2}

    .stars.active{animation:moveStars 20s linear infinite}
    .stars2.active{animation:moveStars 40s linear infinite}

    @keyframes moveStars{
      from{background-position:0 0}
      to{background-position:0 2000px}
    }

    /* COHETE ANIMACION */
    .launch{transform:translateY(-500px) scale(1.3) rotate(-5deg)}

    /* HUMO */
    .smoke{
      position:absolute;bottom:150px;width:20px;height:20px;
      background:rgba(255,255,255,0.5);
      border-radius:50%;opacity:0;filter:blur(2px)
    }

    .smoke.active{animation:smokeAnim 2s infinite}

    @keyframes smokeAnim{
      0%{transform:translateY(0) scale(1);opacity:.7}
      100%{transform:translateY(200px) scale(2);opacity:0}
    }

    section{padding:100px 40px;text-align:center}

    .cards{
      display:flex;justify-content:center;gap:30px;
      flex-wrap:wrap;margin-top:40px
    }

    .card{
      background:#0d1330;padding:25px;border-radius:15px;
      width:220px;transition:.4s;box-shadow:0 0 15px rgba(255,255,255,0.1)
    }

    .card:hover{
      transform:translateY(-10px) scale(1.05);
      background:#151c4d
    }

    footer{background:#000;padding:20px;text-align:center}

    /* RESPONSIVE */
    @media(max-width:768px){
      .title{font-size:2rem}
      header{padding:10px 20px}
      nav{display:none}
    }
  </style>
</head>
<body>

<header>
  <h1>🚀 SpaceXplore</h1>
  <nav>
    <a href="#">Inicio</a>
    <a href="#info">Exploración</a>
    <a href="#galeria">Galaxias</a>
    <a href="#contacto">Contacto</a>
  </nav>
</header>

<div class="hero">
  <div class="stars" id="stars"></div>
  <div class="stars2" id="stars2"></div>

  <div class="smoke" id="smoke"></div>

  <img src="planeta.jpg" id="rocket">

  <h2 class="title" id="title">Explora el universo</h2>
  <button class="btn" onclick="launchRocket()">Lanzar misión 🚀</button>
</div>

<section id="info">
  <h2>¿Qué es este viaje?</h2>
  <p>Una experiencia interactiva donde el espacio cobra vida con animaciones y efectos visuales.</p>

  <div class="cards">
    <div class="card">🪐 Planetas dinámicos</div>
    <div class="card">🚀 Lanzamientos</div>
    <div class="card">✨ Estrellas animadas</div>
  </div>
</section>

<section id="galeria">
  <h2>Galaxias</h2>
  <p>Explora diferentes estilos visuales inspirados en el universo.</p>
</section>

<section id="contacto">
  <h2>Únete a la misión</h2>
  <button class="btn">Registrarse</button>
</section>

<footer>
  <p>© 2026 Exploración Espacial | Hecho por Cristian</p>
</footer>

<script>
  function launchRocket(){
    const rocket = document.getElementById('rocket');
    const stars = document.getElementById('stars');
    const stars2 = document.getElementById('stars2');
    const smoke = document.getElementById('smoke');
    const title = document.getElementById('title');

    rocket.classList.add('launch');
    stars.classList.add('active');
    stars2.classList.add('active');
    smoke.classList.add('active');

    title.innerText = "Misión en progreso...";

    // SONIDO OPCIONAL
    const audio = new Audio('https://www.soundjay.com/mechanical/rocket-launch-01.mp3');
    audio.play();
  }
</script>

</body>
</html>
